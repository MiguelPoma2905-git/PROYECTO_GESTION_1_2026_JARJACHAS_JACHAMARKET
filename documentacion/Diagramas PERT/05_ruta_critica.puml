@startuml
title Ruta Crítica - Proyecto JachaMarket\nActividades de Gestión del Proyecto
caption Flechas rojas = Ruta Crítica\nLa ruta crítica determina la duración mínima del proyecto

skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam nodeSep 60
skinparam rankSep 80

left to right direction

' Nodos
rectangle "<size:10><b>1</b></size>\nAnálisis\nRequerimientos\n(2-3-5)\nTE=3.2" as A1
rectangle "<size:10><b>2</b></size>\nDiseño\nArquitectura\n(3-4-6)\nTE=4.2" as A2
rectangle "<size:10><b>3</b></size>\nDiseño BD\n(2-3-5)\nTE=3.2" as A3
rectangle "<size:10><b>4</b></size>\nConfiguración\nEntorno\n(1-2-3)\nTE=2" as A4
rectangle "<size:10><b>5</b></size>\nDesarrollo\nSprints 1-4\n(15-20-30)\nTE=20.8" as A5
rectangle "<size:10><b>6</b></size>\nPruebas\nUnitarias\n(3-5-7)\nTE=5" as A6
rectangle "<size:10><b>7</b></size>\nPruebas\nIntegración\n(2-4-6)\nTE=4" as A7
rectangle "<size:10><b>8</b></size>\nPruebas\nAceptación\n(2-3-5)\nTE=3.2" as A8
rectangle "<size:10><b>9</b></size>\nDespliegue\n(1-2-3)\nTE=2" as A9
rectangle "<size:10><b>10</b></size>\nDocumentación\nTécnica\n(2-3-5)\nTE=3.2" as A10
rectangle "<size:10><b>11</b></size>\nCapacitación\nUsuarios\n(2-3-4)\nTE=3" as A11

' No críticas (gris)
A1 -[#LightGray]-> A2
A2 -[#LightGray]-> A4
A5 -[#LightGray]-> A10
A10 -[#LightGray]-> A11

' Ruta crítica (rojo)
A1 -[#Red]> A3
A3 -[#Red]> A4
A4 -[#Red]> A5
A5 -[#Red]> A6
A6 -[#Red]> A7
A7 -[#Red]> A8
A8 -[#Red]> A9

' Nota de cálculo
note bottom of A9
  <b>Duración Total del Proyecto:</b>
  1(3.2) + 3(3.2) + 4(2) + 5(20.8)
  + 6(5) + 7(4) + 8(3.2) + 9(2)
  = <b>43.4 días hábiles</b>
  
  <b>Ruta Crítica:</b>
  1 → 3 → 4 → 5 → 6 → 7 → 8 → 9
end note

@enduml
