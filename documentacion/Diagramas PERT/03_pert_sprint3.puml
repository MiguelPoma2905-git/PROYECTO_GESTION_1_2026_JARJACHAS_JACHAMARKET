rectangle "<size:9><b>SP3.3</b></size>\nCode Review\nRevisión de pares\nValidar estándares\n(1 - 2 - 3)\n<b>TE=2</b>" as T03
rectangle "<size:9><b>SP3.4</b></size>\nPruebas de\nIntegración\nVerificar conexión módulos\n(2 - 3 - 4)\n<b>TE=3</b>" as T04
rectangle "<size:9><b>SP3.5</b></size>\nSprint Review\nDemostración al PO\nValidar funcionalidad\n(1 - 1 - 1)\n<b>TE=1</b>" as T05
rectangle "<size:9><b>SP3.6</b></size>\nRetrospectiva\nIdentificar mejoras\nAjustar ritmo\n(1 - 1 - 1)\n<b>TE=1</b>" as T06

