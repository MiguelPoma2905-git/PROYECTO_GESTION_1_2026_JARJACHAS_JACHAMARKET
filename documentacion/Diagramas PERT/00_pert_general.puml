@startuml
title Diagrama PERT General - JachaMarket\nProyecto: Marketplace Multiroles
caption Duración en días (O - M - P) = Optimista - Más Probable - Pesimista\nTE = (O + 4M + P) / 6  |  σ = (P - O) / 6

skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam nodeSep 60
skinparam rankSep 80

left to right direction

rectangle "<size:10><b>P1</b></size>\nRelevamiento\nRequerimientos\n(1 - 2 - 3)\n<b>TE=2</b>" as P1
rectangle "<size:10><b>P2</b></size>\nDiseño\nArquitectura MVC\n(2 - 3 - 5)\n<b>TE=3.2</b>" as P2
rectangle "<size:10><b>P3</b></size>\nDiseño\nBase de Datos\n(2 - 4 - 6)\n<b>TE=4</b>" as P3

rectangle "<size:10><b>S1</b></size>\nSprint 1:\nFundación y\nAutenticación\n(4 - 6 - 8)\n<b>TE=6</b>" as S1
rectangle "<size:10><b>S2</b></size>\nSprint 2:\nPerfil y\nEmprendimiento\n(5 - 7 - 10)\n<b>TE=7.2</b>" as S2
rectangle "<size:10><b>S3</b></size>\nSprint 3:\nProductos, Tienda,\nCarrito y Pedidos\n(5 - 8 - 12)\n<b>TE=8.2</b>" as S3
rectangle "<size:10><b>S4</b></size>\nSprint 4:\nDelivery, Admin\ny Cierre\n(4 - 6 - 9)\n<b>TE=6.2</b>" as S4

rectangle "<size:10><b>PR</b></size>\nPruebas\nIntegrales\n(3 - 5 - 8)\n<b>TE=5.2</b>" as PR
rectangle "<size:10><b>DP</b></size>\nDespliegue y\nDocumentación\n(1 - 2 - 3)\n<b>TE=2</b>" as DP

P1 --> P2
P1 --> P3

P2 --> S1
P3 --> S1

S1 --> S2
S2 --> S3
S3 --> S4

S4 --> PR
PR --> DP

' Critical Path (en rojo)
skinparam backgroundColor #transparent
skinparam rectangle {
  BorderColor #000000
  FontColor #000000
}
@enduml
