@startuml
title Módulo 6: Tienda Pública (Frontend) - Casos de Uso

skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam nodeSep 120
skinparam rankSep 120

left to right direction

actor "Cliente" as C
actor "Visitante" as V

rectangle "Tienda Pública" {
  usecase "Ver Página Principal" as UC1
  usecase "Explorar Negocios Destacados" as UC2
  usecase "Explorar Todos los Negocios" as UC3
  usecase "Visitar Tienda de Negocio" as UC4
  usecase "Buscar Productos en Tienda" as UC5
  usecase "Filtrar por Categoría" as UC6

  C --> UC1
  V --> UC1
  C --> UC3
  V --> UC3

  UC1 --> UC2 : <<incluye>>
  UC2 --> UC4 : <<incluye>>
  UC3 --> UC4 : <<incluye>>
  UC4 --> UC5 : <<incluye>>
  UC6 --> UC5 : <<extiende>>
}

@enduml
