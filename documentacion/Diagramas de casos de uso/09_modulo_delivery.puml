@startuml
title Módulo 9: Delivery y Logística - Casos de Uso

skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam nodeSep 120
skinparam rankSep 120

left to right direction

actor "Repartidor" as R
actor "Sistema" as S

rectangle "Delivery y Logística" {
  usecase "Ver Pedidos Pendientes" as UC1
  usecase "Asignarse un Pedido" as UC2
  usecase "Marcar Pedido en Ruta" as UC3
  usecase "Marcar Pedido Entregado" as UC4
  usecase "Actualizar Pago a Completado" as UC5

  usecase "Ver Estadísticas de Delivery" as UC6

  R --> UC1
  R --> UC6

  UC1 --> UC2 : <<incluye>>
  UC2 --> UC3 : <<incluye>>
  UC3 --> UC4 : <<incluye>>
  UC4 --> UC5 : <<incluye>>
  S --> UC5
}

@enduml
