@startuml
title Diagrama General de Casos de Uso - JachaMarket

skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam nodeSep 120
skinparam rankSep 120
skinparam packageMargin 40

left to right direction

actor "Visitante" as V
actor "Cliente" as C
actor "Emprendedor" as E
actor "Repartidor" as R
actor "Administrador" as A

rectangle "Módulo 1\nAutenticación" as MOD1 {
  usecase "CU-01: Registrarse" as UC1
  usecase "CU-02: Iniciar Sesión" as UC2
  usecase "CU-04: Cerrar Sesión" as UC4
  usecase "CU-05: Seleccionar Roles" as UC5
  V --> UC1
  V --> UC2
  C --> UC2
  UC4 -- C
  UC4 -- E
  UC4 -- R
  UC4 -- A
}

rectangle "Módulo 2\nRoles y Permisos" as MOD2 {
  usecase "Gestionar Roles" as UC_ROL1
  usecase "Cambiar Rol Activo" as UC_ROL2
  usecase "Eliminar Rol Repartidor" as UC_ROL3
  A --> UC_ROL1
  C --> UC_ROL2
  E --> UC_ROL2
  R --> UC_ROL2
  C --> UC_ROL3
  E --> UC_ROL3
}

rectangle "Módulo 4\nEmprendimiento" as MOD4 {
  usecase "Crear Negocio" as UC_EMP2
  usecase "Personalizar Tienda" as UC_EMP3
  usecase "Gestionar Sucursales" as UC_EMP4
  usecase "Eliminar Negocio" as UC_EMP5
  E --> UC_EMP2
  E --> UC_EMP3
  E --> UC_EMP4
  E --> UC_EMP5
}

rectangle "Módulo 5\nProductos" as MOD5 {
  usecase "Gestionar Productos" as UC_PROD1

  E --> UC_PROD1
}

rectangle "Módulo 6\nTienda Pública" as MOD6 {
  usecase "Explorar Negocios" as UC_TIENDA1
  C --> UC_TIENDA1
  V --> UC_TIENDA1
}

rectangle "Módulo 7-8\nCarrito y Pedidos" as MOD78 {
  usecase "Gestionar Carrito" as UC_CARRITO
  usecase "Realizar Checkout" as UC_CHECKOUT
  C --> UC_CARRITO
  C --> UC_CHECKOUT
}

rectangle "Módulo 9\nDelivery" as MOD9 {
  usecase "Ver Pedidos Pendientes" as UC_DEL1
  usecase "Asignarse Pedido" as UC_DEL2
  usecase "Marcar Entregado" as UC_DEL3
  R --> UC_DEL1
  R --> UC_DEL2
  R --> UC_DEL3
}

rectangle "Módulo 10-11\nAdministración" as MOD1011 {
  usecase "Ver Panel Admin" as UC_ADM1
  usecase "Gestionar Usuarios" as UC_ADM2
  usecase "Gestionar Reportes" as UC_ADM3
  A --> UC_ADM1
  A --> UC_ADM2
  A --> UC_ADM3
}

@enduml
