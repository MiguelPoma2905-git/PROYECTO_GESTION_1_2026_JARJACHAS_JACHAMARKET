RewriteEngine On

# Si la URL es la raíz exacta, ir directo al front controller
RewriteRule ^$ public/index.php [L]

# Si es un archivo real (no directorio), servirlo directamente
RewriteCond %{REQUEST_FILENAME} -f
RewriteRule ^ - [L]

# Todo lo demás redirigir a public
RewriteRule ^(.*)$ public/$1 [L]

# Proteger archivos sensibles
<FilesMatch "\.(env|sql|log|ini)$">
    Order allow,deny
    Deny from all
</FilesMatch>

# Configuración PHP
php_value upload_max_filesize 20M
php_value post_max_size 20M
php_value max_execution_time 300
