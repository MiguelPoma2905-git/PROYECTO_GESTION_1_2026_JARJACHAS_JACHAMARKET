' ============= RELACIONES =============

usuarios --> usuario_roles
roles --> usuario_roles
roles --> rol_permiso
permisos --> rol_permiso
usuarios --> emprendimientos : id_propietario
emprendimientos --> sucursales
emprendimientos --> personalizacion
plantillas --> personalizacion
emprendimientos --> emprendimiento_repartidores
usuarios --> emprendimiento_repartidores : id_repartidor
categorias --> categorias : auto-ref
emprendimientos --> productos
categorias --> productos
productos --> variantes_producto
variantes_producto --> inventario
sucursales --> inventario
inventario --> movimientos_kardex
usuarios --> movimientos_kardex : id_responsable
usuarios --> pedidos : id_cliente
sucursales --> pedidos : id_origen
pedidos --> detalles_pedido
variantes_producto --> detalles_pedido
pedidos --> envios_logistica
usuarios --> envios_logistica : id_repartidor
usuarios --> logs_auditoria

@enduml
