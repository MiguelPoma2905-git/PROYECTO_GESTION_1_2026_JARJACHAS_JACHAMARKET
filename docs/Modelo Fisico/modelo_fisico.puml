@startuml
!theme plain

skinparam backgroundColor #FDFBF7
skinparam defaultFontName Arial
skinparam defaultFontSize 11

skinparam class {
  BackgroundColor #ffffff
  BorderColor #2C3E50
  FontColor #1a1a2e
  HeaderBackgroundColor #1a1a2e
  HeaderFontColor #FDFBF7
}

skinparam arrow {
  Color #2C3E50
  FontColor #2C3E50
  FontSize 9
}

