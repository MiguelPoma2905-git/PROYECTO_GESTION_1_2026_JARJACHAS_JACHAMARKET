@startuml
title PERT - Sprint 1: Planificación y Fundación\nActividades de Gestión del Proyecto
caption Duración en días (O - M - P)\nActividades del proyecto, no del sistema

skinparam linetype ortho
skinparam defaultTextAlignment center
skinparam nodeSep 50
skinparam rankSep 70

left to right direction

rectangle "<size:9><b>SP1.1</b></size>\nSprint Planning\nPlanificar tareas del Sprint\nDefinir objetivos\n(1 - 1 - 2)\n<b>TE=1.2</b>" as T01
rectangle "<size:9><b>SP1.2</b></size>\nDesarrollo Diario\nCodificación continua\nReuniones diarias (daily)\n(5 - 7 - 10)\n<b>TE=7.2</b>" as T02
rectangle "<size:9><b>SP1.3</b></size>\nCode Review\nRevisión de código\nentre pares\n(1 - 2 - 3)\n<b>TE=2</b>" as T03
rectangle "<size:9><b>SP1.4</b></size>\nControl de Calidad\nPruebas de humo\nVerificación de entregables\n(1 - 2 - 3)\n<b>TE=2</b>" as T04
rectangle "<size:9><b>SP1.5</b></size>\nSprint Review\nDemostración al PO\nValidación de cumplimiento\n(1 - 1 - 1)\n<b>TE=1</b>" as T05
rectangle "<size:9><b>SP1.6</b></size>\nRetrospectiva\nIdentificar mejoras\nAjustar procesos\n(1 - 1 - 1)\n<b>TE=1</b>" as T06

T01 --> T02
T02 --> T03
T02 --> T04
T03 --> T05
T04 --> T05
T05 --> T06

@enduml
